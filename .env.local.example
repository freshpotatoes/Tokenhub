# ===== 当前阶段(MVP): 使用本地 mock JSON,不需要填以下变量 =====
# ===== 接入 Supabase 后取消注释并填写 =====

# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== 站点监控 =====
# 部署到 Vercel 后,在 Vercel Dashboard → Settings → Cron Jobs 添加:
# 路径: /api/monitor  频率: 每 30 分钟一次
# Vercel 会自动设置 CRON_SECRET 环境变量来保护 Cron Job 端点
# CRON_SECRET= 由 Vercel 自动注入
