# ===== Supabase 配置 (必须) =====
# 在 Supabase Dashboard → Settings → Data API 中获取以下三个值

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (sb_publishable_ 开头,等同于旧版 anon key,可公开)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret key (sb_secret_ 开头,等同于旧版 service_role key,绝密!)
# ⚠️ 不带 NEXT_PUBLIC_ 前缀,不会暴露到浏览器
# ⚠️ 不要提交到 GitHub
TOKENHUB_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ===== 站点域名 (必须) =====
# Vercel 部署后设为实际域名,本地开发可不设(默认 example.com 仅用于 sitemap)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===== 管理后台 (必须) =====
# 用于 /admin 审核页面的访问密码
ADMIN_SECRET=设置一个只有你知道的密码

# ===== 站点监控 (可选) =====
# 部署到 Vercel 后,在 Settings → Cron Jobs 添加:
# 路径: /api/monitor  频率: 每 30 分钟一次
# Vercel 会自动注入 CRON_SECRET,无需手动设置
